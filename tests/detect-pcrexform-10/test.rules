# must_error on one buffer, content on another buffer (cross-buffer)

# pcrexform does NOT match -> error -> must_error matches;
# http.host content matches -> alert
alert http any any -> any any (msg:"must_error cross-buffer alert"; http.request_line; pcrexform:"(XXXNOMATCHXXX)"; absent: must_error; http.host; content:"i.imgur.com"; sid:1;)

# pcrexform matches -> no error -> must_error fails -> no alert
alert http any any -> any any (msg:"must_error cross-buffer no error"; http.request_line; pcrexform:"[a-zA-Z]+\s+(.*)\s+HTTP"; absent: must_error; http.host; content:"i.imgur.com"; sid:2;)

# pcrexform does NOT match -> error -> must_error matches;
# http.host content does not match -> no alert
alert http any any -> any any (msg:"must_error cross-buffer host miss"; http.request_line; pcrexform:"(XXXNOMATCHXXX)"; absent: must_error; http.host; content:"evil.com"; sid:3;)
