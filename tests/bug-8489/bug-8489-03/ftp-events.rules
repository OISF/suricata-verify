# response rule is required to keep Suricata's to_client FTP parsing active
# so responses complete pending transactions; without it the max-tx check
# does not fire in the to_server direction.
alert ftp any any -> any any (msg:"SURICATA FTP Response command too long"; flow:to_client; app-layer-event:ftp.response_command_too_long; classtype:protocol-command-decode; sid:2;)
alert ftp any any -> any any (msg:"SURICATA FTP too many transactions"; flow:to_server; app-layer-event:ftp.too_many_transactions; classtype:protocol-command-decode; sid:3;)
