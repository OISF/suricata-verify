alert smb any any -> any any (msg:"SMB DCERPC ptype bind"; flow:established,to_server; dcerpc.ptype:11; sid:1;)
alert smb any any -> any any (msg:"SMB DCERPC ptype bind_ack"; flow:established,to_client; dcerpc.ptype:12; sid:2;)
alert smb any any -> any any (msg:"SMB DCERPC ptype request"; flow:established,to_server; dcerpc.ptype:0; sid:3;)
alert smb any any -> any any (msg:"SMB DCERPC ptype response"; flow:established,to_client; dcerpc.ptype:2; sid:4;)
