# Allow all TCP handshakes and established packets.
accept:hook tcp:all any any -> any any (flow:not_established; sid:1000;)
accept:hook tcp:all any any <> any any (flow:established; sid:1001;)

# Accept every SMTP request/response hook; this test only cares about whether
# the transaction ever transitions to the request_data (DATA) state.
accept:hook smtp:request_started any any -> any any (sid:2000;)
accept:hook smtp:request_complete any any -> any any (sid:2010;)
accept:hook smtp:response_started any any -> any any (sid:3000;)
accept:hook smtp:response_data any any -> any any (sid:3005;)
accept:hook smtp:response_complete any any -> any any (sid:3010;)

# Tripwire: alert on any transition to the request_data (DATA) state. A
# QUIT-after-MAIL session abandons the envelope before DATA, so this must never
# fire. The test asserts a count of 0; if a future change let an abandoned
# envelope advance to DATA, this alert would fire and the test would fail.
accept:hook,alert smtp:request_data any any -> any any (sid:2006; \
	msg:"SMTP entered request_data";)
