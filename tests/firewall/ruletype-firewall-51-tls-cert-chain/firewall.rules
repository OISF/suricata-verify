# allow session setup
accept:hook tcp:all $HOME_NET any <> $EXTERNAL_NET any (flow:not_established; alert; sid:1021;)
accept:hook tcp:all $HOME_NET any <> $EXTERNAL_NET 443 (flow:established; alert; sid:1022;)

accept:hook tls:client_in_progress $HOME_NET any -> $EXTERNAL_NET any (alert; sid:101;)
drop:flow tls:client_hello_done $HOME_NET any -> $EXTERNAL_NET any (tls.version:1.0; msg:"TLS 1.0 not allowed"; sid:102;)
accept:hook tls:client_hello_done $HOME_NET any -> $EXTERNAL_NET any (tls.sni; content:"www.google.com"; sid:103; alert;)
accept:hook tls:client_cert_done $HOME_NET any -> $EXTERNAL_NET any (alert; sid:104;)
accept:hook tls:client_handshake_done $HOME_NET any -> $EXTERNAL_NET any (alert; sid:105;)
accept:hook tls:client_finished $HOME_NET any -> $EXTERNAL_NET any (alert; sid:106;)

accept:hook tls:server_in_progress $EXTERNAL_NET any -> $HOME_NET any (alert; sid:107;)
accept:hook tls:server_hello $EXTERNAL_NET any -> $HOME_NET any (alert; sid:108;)
drop:flow tls:server_hello_done $EXTERNAL_NET any -> $HOME_NET any (tls.version:1.0; msg:"TLS 1.0 not allowed"; sid:109;)
accept:hook tls:server_hello_done $EXTERNAL_NET any -> $HOME_NET any (alert; sid:110;)
accept:flow tls:server_cert_done $EXTERNAL_NET any -> $HOME_NET any (tls.cert_chain_len:>2; sid:111; msg:"TLS certs chain length check"; alert;)
# other hooks skipped


# Implicit drop all else
